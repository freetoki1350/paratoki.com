---
interface Props {
  title: string;
  description?: string;
  contentMaxWidth?: string;
}

const {
  title,
  description = "Paratoki Lab — 日々の暮らしに寄り添うアプリを開発しています。",
  contentMaxWidth = "800px",
} = Astro.props;

const fullTitle = title === "Paratoki Lab" ? title : `${title} | Paratoki Lab`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <title>{fullTitle}</title>
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5830483562454167"
      crossorigin="anonymous"></script>
  </head>
  <body>
    <main style={`max-width: ${contentMaxWidth}; margin: 0 auto; padding: 40px 20px;`}>
      <slot />
    </main>
    <style is:global>
      :root {
        color-scheme: light;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN",
          "Hiragino Sans", Meiryo, sans-serif;
        color: #333;
        margin: 0;
        line-height: 1.7;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 0.2em;
      }
      h2 {
        font-size: 1.3em;
        margin-top: 2em;
      }
      a {
        color: #1a73e8;
      }
      a:hover {
        text-decoration: none;
      }
      .tagline {
        color: #666;
        margin-bottom: 2em;
      }
      .app {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 16px;
      }
      .app h2 {
        margin: 0 0 8px;
        font-size: 1.2em;
      }
      .app a {
        text-decoration: none;
      }
      .app h2 a {
        color: #333;
      }
      .app-links {
        font-size: 0.9em;
        color: #666;
        margin-top: 8px;
      }
      footer {
        margin-top: 3em;
        color: #999;
        font-size: 0.85em;
        border-top: 1px solid #eee;
        padding-top: 1em;
      }
      nav.site-nav {
        display: flex;
        gap: 16px;
        margin-bottom: 2em;
        font-size: 0.9em;
      }
      nav.site-nav a {
        text-decoration: none;
      }
    </style>
  </body>
</html>
