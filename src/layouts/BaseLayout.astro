---
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  contentMaxWidth?: string;
  image?: string;
}

const {
  title,
  description = "Paratoki Lab — 日々の暮らしに寄り添うアプリを開発しています。",
  contentMaxWidth = "800px",
  image,
} = Astro.props;

const fullTitle = title === "Paratoki Lab" ? title : `${title} | Paratoki Lab`;
const ogImage = image ? new URL(image, Astro.site).toString() : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <!-- OGP -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <title>{fullTitle}</title>
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5830483562454167"
      crossorigin="anonymous"></script>
    <Analytics />
  </head>
  <body>
    <main style={`max-width: ${contentMaxWidth}; margin: 0 auto; padding: 40px 20px;`}>
      <slot />
    </main>
    <script is:inline>
      // 外部リンククリックを GA4 に outbound_click として送信
      document.addEventListener("click", (e) => {
        const a = e.target.closest("a");
        if (!a) return;
        const href = a.href;
        if (!href || href.includes(location.host)) return;
        if (typeof gtag !== "function") return;
        try {
          gtag("event", "outbound_click", {
            url: href,
            domain: new URL(href).hostname,
            label: a.textContent?.trim().slice(0, 80) ?? "",
          });
        } catch (_) {
          // URL パース失敗時は何もしない
        }
      });
    </script>
    <style is:global>
      :root {
        color-scheme: light;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN",
          "Hiragino Sans", Meiryo, sans-serif;
        color: #333;
        margin: 0;
        line-height: 1.7;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 0.2em;
      }
      h2 {
        font-size: 1.3em;
        margin-top: 2em;
      }
      a {
        color: #1a73e8;
      }
      a:hover {
        text-decoration: none;
      }
      .tagline {
        color: #666;
        margin-bottom: 2em;
      }
      .app {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 16px;
      }
      .app h2,
      .app h3 {
        margin: 0 0 8px;
        font-size: 1.2em;
      }
      .app a {
        text-decoration: none;
      }
      .app h2 a,
      .app h3 a {
        color: #333;
      }
      footer {
        margin-top: 3em;
        color: #999;
        font-size: 0.85em;
        border-top: 1px solid #eee;
        padding-top: 1em;
      }
      nav.site-nav {
        display: flex;
        gap: 16px;
        margin-bottom: 2em;
        font-size: 0.9em;
      }
      nav.site-nav a {
        text-decoration: none;
      }
    </style>
  </body>
</html>
