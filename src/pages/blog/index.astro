---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const standalonePosts = allPosts
  .filter((p) => !p.data.series)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Group series posts by series name
const seriesMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  if (!post.data.series) continue;
  const arr = seriesMap.get(post.data.series) ?? [];
  arr.push(post);
  seriesMap.set(post.data.series, arr);
}
// Sort each series by seriesNo ascending
for (const [name, posts] of seriesMap) {
  seriesMap.set(
    name,
    posts.sort((a, b) => (a.data.seriesNo ?? 0) - (b.data.seriesNo ?? 0)),
  );
}

const SERIES_TOTAL: Record<string, number> = {
  "LINE ミニアプリ開発記": 15,
};

const formatDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;
---

<BaseLayout title="ブログ" description="Paratoki Lab の開発・運営に関する記事">
  <nav class="site-nav">
    <a href="/">ホーム</a>
    <a href="/blog/">ブログ</a>
    <a href="/about/">運営者情報</a>
  </nav>

  <h1>ブログ</h1>
  <p class="tagline">アプリ開発・運営の記録、技術メモ、雑記など。</p>

  {
    standalonePosts.length > 0 && (
      <section class="blog-section">
        <h2>記事</h2>
        <ul class="post-list">
          {standalonePosts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`} class="post-title">
                {post.data.title}
              </a>
              <p class="post-meta">
                <time datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
              </p>
              <p class="excerpt">{post.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    Array.from(seriesMap.entries()).map(([seriesName, posts]) => {
      const total = SERIES_TOTAL[seriesName];
      return (
        <section class="blog-section">
          <h2>連載: {seriesName}</h2>
          <p class="series-progress">
            {total ? `全 ${total} 回構成` : "連載中"}・現在 {posts.length} 回公開中
          </p>
          <ul class="post-list series-list">
            {posts.map((post) => (
              <li>
                <span class="series-num">第 {post.data.seriesNo} 回</span>
                <a href={`/blog/${post.slug}/`} class="post-title">
                  {post.data.title}
                </a>
                <p class="excerpt">{post.data.description}</p>
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }

  <Footer />
</BaseLayout>

<style>
  .blog-section {
    margin-top: 2.5em;
  }
  .blog-section h2 {
    border-bottom: 2px solid #1a73e8;
    padding-bottom: 0.3em;
    margin-bottom: 0.8em;
  }
  .series-progress {
    color: #666;
    font-size: 0.9em;
    margin: -0.5em 0 1em;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    padding: 16px 0;
    border-bottom: 1px solid #eee;
  }
  .post-list .post-title {
    font-size: 1.1em;
    font-weight: 600;
    text-decoration: none;
  }
  .post-meta {
    color: #999;
    font-size: 0.85em;
    margin: 4px 0 0;
  }
  .excerpt {
    color: #666;
    font-size: 0.95em;
    margin: 8px 0 0;
  }
  .series-list .series-num {
    display: inline-block;
    background: #e8f0fe;
    color: #1a73e8;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.85em;
    font-weight: 600;
    margin-right: 10px;
    vertical-align: middle;
  }
</style>
