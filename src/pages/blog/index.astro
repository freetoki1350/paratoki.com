---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import Footer from "../../components/Footer.astro";
import { seriesIndex } from "../../data/series.ts";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

const standalonePosts = allPosts
  .filter((p) => !p.data.series)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

// Map series posts by `${series}/${seriesNo}` for quick lookup
const seriesPostMap = new Map<string, (typeof allPosts)[number]>();
for (const post of allPosts) {
  if (post.data.series && post.data.seriesNo != null) {
    seriesPostMap.set(`${post.data.series}/${post.data.seriesNo}`, post);
  }
}

const formatDate = (d: Date) =>
  `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日`;

const seriesSections = Object.entries(seriesIndex).map(([name, entries]) => {
  const total = entries.length;
  const publishedCount = entries.filter((e) =>
    seriesPostMap.has(`${name}/${e.no}`),
  ).length;
  return { name, entries, total, publishedCount };
});
---

<BaseLayout title="ブログ" description="Paratoki Lab の開発・運営に関する記事">
  <SiteNav />

  <h1>ブログ</h1>
  <p class="tagline">アプリ開発・運営の記録、技術メモ、雑記など。</p>

  {
    standalonePosts.length > 0 && (
      <section class="blog-section">
        <h2>記事</h2>
        <ul class="post-list">
          {standalonePosts.map((post) => (
            <li>
              <a href={`/blog/${post.slug}/`} class="post-title">
                {post.data.title}
              </a>
              <p class="post-meta">
                <time datetime={post.data.publishDate.toISOString()}>
                  {formatDate(post.data.publishDate)}
                </time>
              </p>
              <p class="excerpt">{post.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    seriesSections.map(({ name, entries, total, publishedCount }) => (
      <section class="blog-section">
        <h2>連載: {name}</h2>
        <p class="series-progress">
          全 {total} 回構成・現在 {publishedCount} 回公開中
        </p>
        <p class="series-intro-link">
          → <a href="/series/line-mini-app/">連載の概要・読み方ガイドはこちら</a>
        </p>
        <ul class="series-list">
          {entries.map((entry) => {
            const post = seriesPostMap.get(`${name}/${entry.no}`);
            const published = !!post;
            return (
              <li class={published ? "published" : "upcoming"}>
                <span class="series-num">第 {entry.no} 回</span>
                {published ? (
                  <a href={`/blog/${post!.slug}/`} class="series-title">
                    {entry.title}
                  </a>
                ) : (
                  <span class="series-title">
                    {entry.title}
                    <span class="upcoming-badge">後日掲載</span>
                  </span>
                )}
              </li>
            );
          })}
        </ul>
      </section>
    ))
  }

  <Footer />
</BaseLayout>

<style>
  .blog-section {
    margin-top: 2.5em;
  }
  .blog-section h2 {
    border-bottom: 2px solid #1a73e8;
    padding-bottom: 0.3em;
    margin-bottom: 0.8em;
  }
  .series-progress {
    color: #666;
    font-size: 0.9em;
    margin: -0.5em 0 0.3em;
  }
  .series-intro-link {
    font-size: 0.95em;
    margin: 0 0 1em;
  }
  .post-list {
    list-style: none;
    padding: 0;
  }
  .post-list li {
    padding: 16px 0;
    border-bottom: 1px solid #eee;
  }
  .post-list .post-title {
    font-size: 1.1em;
    font-weight: 600;
    text-decoration: none;
  }
  .post-meta {
    color: #999;
    font-size: 0.85em;
    margin: 4px 0 0;
  }
  .excerpt {
    color: #666;
    font-size: 0.95em;
    margin: 8px 0 0;
  }
  .series-list {
    list-style: none;
    padding: 0;
  }
  .series-list li {
    padding: 12px 0;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .series-list li.upcoming {
    opacity: 0.55;
  }
  .series-num {
    flex-shrink: 0;
    background: #e8f0fe;
    color: #1a73e8;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.85em;
    font-weight: 600;
    line-height: 1.6;
  }
  .upcoming .series-num {
    background: #f0f0f0;
    color: #999;
  }
  .series-title {
    flex: 1;
    font-size: 1em;
    text-decoration: none;
    color: #1a73e8;
  }
  .upcoming .series-title {
    color: #999;
    cursor: default;
  }
  .upcoming-badge {
    display: inline-block;
    margin-left: 8px;
    padding: 1px 8px;
    background: #f5f5f5;
    color: #888;
    font-size: 0.75em;
    border-radius: 4px;
    font-weight: normal;
  }
</style>
